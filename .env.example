# Lumina AI OS - Environment Configuration

# Application
APP_NAME=Lumina AI OS
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Security
SECRET_KEY=change-this-to-a-secure-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql://lumina:lumina123@localhost:5432/lumina_ai_os

# Redis
REDIS_URL=redis://localhost:6379/0

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LOCAL_AI_URL=http://localhost:11434
LOCAL_AI_MODEL=llama3

# ChromaDB
CHROMA_DB_PATH=./chroma_db

# Logging
LOG_LEVEL=INFO
