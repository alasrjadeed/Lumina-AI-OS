{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Open Lumina Dashboard",
      "type": "shell",
      "command": "xdg-open http://localhost:5173",
      "problemMatcher": [],
      "group": "none"
    },
    {
      "label": "Open Lumina API Docs",
      "type": "shell",
      "command": "xdg-open http://localhost:8000/docs",
      "problemMatcher": [],
      "group": "none"
    },
    {
      "label": "Start Lumina Backend",
      "type": "shell",
      "command": "source venv/bin/activate && uvicorn main:app --host 0.0.0.0 --port 8000",
      "problemMatcher": [],
      "group": "none"
    },
    {
      "label": "Start Lumina Frontend",
      "type": "shell",
      "command": "npm run dev -- --host 0.0.0.0",
      "options": { "cwd": "${workspaceFolder}/lumina-ui" },
      "problemMatcher": [],
      "group": "none"
    }
  ]
}
